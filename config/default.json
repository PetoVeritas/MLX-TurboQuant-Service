{
  "server": {
    "host": "127.0.0.1",
    "port": 4017,
    "adminLocalOnly": true
  },
  "model": {
    "id": "mlx-gemma-test",
    "path": "",
    "maxOutputTokens": 8192,
    "sampling": {
      "temperature": 0.7,
      "topP": 0.9
    },
    "diffusion": {
      "max_denoising_steps": 48,
      "diffusion_sampler": "entropy-bound",
      "prefill_step_size": 2048
    }
  },
  "modalities": {
    "text": {
      "enabled": true
    },
    "image": {
      "enabled": false,
      "maxInputs": 4,
      "maxBytesMb": 20,
      "allowedMimeTypes": ["image/png", "image/jpeg", "image/webp"],
      "transport": ["data_url"]
    },
    "video": {
      "enabled": false,
      "maxInputs": 1,
      "maxBytesMb": 200,
      "allowedMimeTypes": ["video/mp4", "video/quicktime"],
      "transport": ["data_url"],
      "framePolicy": {
        "mode": "sample",
        "maxFrames": 16,
        "fps": 1
      }
    },
    "audio": {
      "enabled": false,
      "maxInputs": 2,
      "maxBytesMb": 50,
      "allowedMimeTypes": ["audio/wav", "audio/mpeg", "audio/mp4", "audio/x-m4a"],
      "transport": ["data_url"],
      "transcode": {
        "enabled": false,
        "targetFormat": "wav",
        "sampleRateHz": 16000
      }
    },
    "document": {
      "enabled": false,
      "maxInputs": 2,
      "maxBytesMb": 20,
      "allowedMimeTypes": ["application/pdf", "text/plain", "text/markdown"],
      "transport": ["data_url"]
    },
    "strictCapabilityCheck": true
  },
  "governor": {
    "enabled": false,
    "instanceId": "mlx-26b",
    "priority": 1,
    "rssEstimateLoadedGb": 29.0,
    "stateDir": "~/Library/Application Support/MLX-TurboQuant-Governor",
    "ceilingGb": 34.0,
    "allowLowerPriorityToPreemptHigher": false,
    "staleAfterSeconds": 900
  },
  "worker": {
    "backend": "mlx_vlm_turboquant",
    "startupTimeoutMs": 120000,
    "requestTimeoutMs": 180000,
    "probeTimeoutMs": 1000,
    "pythonExecutable": "",
    "stubMode": false,
    "lazyLoad": true,
    "idleUnload": {
      "enabled": true,
      "idleMs": 300000
    },
    "recycle": {
      "maxConsecutiveErrors": 3,
      "cooldownMs": 15000
    }
  },
  "logging": {
    "level": "info"
  }
}
