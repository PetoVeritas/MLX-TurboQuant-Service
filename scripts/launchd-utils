#!/usr/bin/env bash
# Shared launchd helpers for local MLX service scripts.

launchd_label() {
  printf '%s' "${MLX_GEMMA_LAUNCHD_LABEL:-com.openclaw.mlx-turbo-gemma-service}"
}

launchd_job_loaded() {
  launchctl print "gui/$UID/$(launchd_label)" >/dev/null 2>&1
}

launchd_job_pid() {
  launchctl print "gui/$UID/$(launchd_label)" 2>/dev/null | awk '/^[[:space:]]*pid = / { print $3; exit }'
}

refuse_if_launchd_loaded() {
  if launchd_job_loaded; then
    cat >&2 <<EOF
Refusing: launchd job $(launchd_label) is loaded.
This script manages only the pidfile/nohup supervisor path and must not fight launchd.
Use launchctl bootout/bootstrap for the LaunchAgent, or set MLX_GEMMA_LAUNCHD_LABEL to the correct sibling label.
EOF
    exit 2
  fi
}

supervisor_pid_for_measurement() {
  local pid_file="$1"
  local pid=""
  if launchd_job_loaded; then
    pid="$(launchd_job_pid || true)"
  fi
  if [[ -z "$pid" && -f "$pid_file" ]]; then
    pid="$(cat "$pid_file" 2>/dev/null || true)"
  fi
  printf '%s' "$pid"
}
