#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
BASE_URL="${MLX_GEMMA_BASE_URL:-http://127.0.0.1:4017}"
OUT_DIR="${MLX_GEMMA_RUN_OUTPUT_DIR:-$ROOT_DIR/tmp/reclaim-runs}"
FIXTURE_PATH="${1:-$ROOT_DIR/benchmarks/long-context-retrieval.fixture.json}"
POST_RUN_WAITS_CSV="${MLX_GEMMA_RECLAIM_POST_RUN_WAITS_CSV:-10,30}"
POST_UNLOAD_WAITS_CSV="${MLX_GEMMA_RECLAIM_POST_UNLOAD_WAITS_CSV:-0,5}"
PID_FILE="$ROOT_DIR/tmp/supervisor.pid"
# shellcheck source=/dev/null
source "$ROOT_DIR/scripts/launchd-utils"

mkdir -p "$OUT_DIR"

json_get() {
  local expr="$1"
  JSON_GET_EXPR="$expr" python3 -c 'import json, os, sys; cur=json.load(sys.stdin)
for part in os.environ["JSON_GET_EXPR"].split("."):
    cur=cur[part]
print(cur)'
}

rss_mb() {
  local pid="$1"
  if [[ -z "$pid" || "$pid" == "None" || "$pid" == "null" ]]; then
    echo ""
    return 0
  fi
  ps -o rss= -p "$pid" 2>/dev/null | awk '{if (NF==0) print ""; else printf "%.1f", $1/1024}'
}

wait_for_health() {
  for _ in {1..80}; do
    if curl -fsS "$BASE_URL/health" >/dev/null 2>&1; then
      return 0
    fi
    sleep 0.25
  done
  echo "Service did not become healthy at $BASE_URL" >&2
  exit 1
}

wait_for_stats() {
  for _ in {1..80}; do
    local body
    body="$(curl -sS "$BASE_URL/admin/stats" 2>/dev/null || true)"
    if [[ -n "$body" ]]; then
      printf '%s' "$body"
      return 0
    fi
    sleep 0.25
  done
  echo "Timed out waiting for /admin/stats at $BASE_URL" >&2
  exit 1
}

measure_json() {
  local label="$1"
  local stats worker_pid worker_state worker_loaded supervisor_pid supervisor_rss worker_rss now_epoch
  stats="$(wait_for_stats)"
  worker_pid="$(printf '%s' "$stats" | json_get worker.pid)"
  worker_state="$(printf '%s' "$stats" | json_get worker.state)"
  worker_loaded="$(printf '%s' "$stats" | json_get worker.loaded)"
  supervisor_pid="$(supervisor_pid_for_measurement "$PID_FILE")"
  supervisor_rss="$(rss_mb "$supervisor_pid")"
  worker_rss="$(rss_mb "$worker_pid")"
  now_epoch="$(python3 - <<'PY'
import time
print(f"{time.time():.3f}")
PY
)"
  LABEL="$label" \
  NOW_EPOCH="$now_epoch" \
  WORKER_STATE="$worker_state" \
  WORKER_LOADED="$worker_loaded" \
  SUPERVISOR_PID="$supervisor_pid" \
  SUPERVISOR_RSS_MB="$supervisor_rss" \
  WORKER_PID="$worker_pid" \
  WORKER_RSS_MB="$worker_rss" \
  python3 - <<'PY'
import json, os
print(json.dumps({
    "label": os.environ.get("LABEL", ""),
    "captured_at_epoch_s": float(os.environ.get("NOW_EPOCH", "0") or 0),
    "worker_state": os.environ.get("WORKER_STATE", ""),
    "worker_loaded": os.environ.get("WORKER_LOADED", ""),
    "supervisor_pid": os.environ.get("SUPERVISOR_PID", ""),
    "supervisor_rss_mb": os.environ.get("SUPERVISOR_RSS_MB", ""),
    "worker_pid": os.environ.get("WORKER_PID", ""),
    "worker_rss_mb": os.environ.get("WORKER_RSS_MB", ""),
}))
PY
}

TIMESTAMP="$(date -u +"%Y%m%dT%H%M%SZ")"
RUN_DIR="$OUT_DIR/${TIMESTAMP}-reclaim"
mkdir -p "$RUN_DIR"

cd "$ROOT_DIR"
if ! launchd_job_loaded; then
  ./scripts/start >/dev/null
fi
wait_for_health
wait_for_stats >/dev/null

measure_json "pre_run" > "$RUN_DIR/pre-run.json"
./scripts/run-fixture "$FIXTURE_PATH" | tee "$RUN_DIR/fixture-run.log"
latest_run_dir="$(ls -1dt "$ROOT_DIR"/tmp/fixture-runs/* 2>/dev/null | head -n 1)"
if [[ -n "$latest_run_dir" && -f "$latest_run_dir/summary.json" ]]; then
  cp "$latest_run_dir/summary.json" "$RUN_DIR/fixture-summary.json"
  printf '%s\n' "$latest_run_dir" > "$RUN_DIR/fixture-run-dir.txt"
fi
measure_json "post_run_immediate" > "$RUN_DIR/post-run-immediate.json"

IFS=',' read -r -a post_run_waits <<< "$POST_RUN_WAITS_CSV"
last_wait=0
for wait_s in "${post_run_waits[@]}"; do
  wait_s="${wait_s// /}"
  [[ -z "$wait_s" ]] && continue
  delta=$((wait_s - last_wait))
  if (( delta > 0 )); then
    sleep "$delta"
  fi
  measure_json "post_run_plus_${wait_s}s" > "$RUN_DIR/post-run-plus-${wait_s}s.json"
  last_wait=$wait_s
done

unload_started_epoch="$(python3 - <<'PY'
import time
print(f"{time.time():.3f}")
PY
)"
curl -sS -X POST "$BASE_URL/admin/worker/unload" > "$RUN_DIR/unload-response.json"
measure_json "post_unload_immediate" > "$RUN_DIR/post-unload-immediate.json"

IFS=',' read -r -a post_unload_waits <<< "$POST_UNLOAD_WAITS_CSV"
last_wait=0
for wait_s in "${post_unload_waits[@]}"; do
  wait_s="${wait_s// /}"
  [[ -z "$wait_s" ]] && continue
  if [[ "$wait_s" == "0" ]]; then
    continue
  fi
  delta=$((wait_s - last_wait))
  if (( delta > 0 )); then
    sleep "$delta"
  fi
  measure_json "post_unload_plus_${wait_s}s" > "$RUN_DIR/post-unload-plus-${wait_s}s.json"
  last_wait=$wait_s
done

RUN_DIR="$RUN_DIR" UNLOAD_STARTED_EPOCH="$unload_started_epoch" python3 - <<'PY'
import json, os
from pathlib import Path
run_dir = Path(os.environ['RUN_DIR'])
unload_started = float(os.environ['UNLOAD_STARTED_EPOCH'])
measurements = []
for path in sorted(run_dir.glob('*.json')):
    if path.name in {'fixture-summary.json', 'summary.json', 'unload-response.json'}:
        continue
    try:
        data = json.loads(path.read_text())
    except Exception:
        continue
    data['_file'] = path.name
    measurements.append(data)
summary = {
    'fixture_run_dir': (run_dir / 'fixture-run-dir.txt').read_text().strip() if (run_dir / 'fixture-run-dir.txt').exists() else None,
    'measurements': measurements,
    'post_run': {},
    'post_unload': {},
}
if (run_dir / 'fixture-summary.json').exists():
    summary['fixture_summary'] = json.loads((run_dir / 'fixture-summary.json').read_text())
for item in measurements:
    label = item.get('label', '')
    try:
        worker_rss = float(item.get('worker_rss_mb'))
    except Exception:
        worker_rss = None
    if label.startswith('post_run'):
        summary['post_run'][label] = {
            'worker_rss_mb': worker_rss,
            'worker_state': item.get('worker_state'),
            'worker_loaded': item.get('worker_loaded'),
        }
    if label.startswith('post_unload'):
        captured = float(item.get('captured_at_epoch_s') or 0)
        summary['post_unload'][label] = {
            'worker_rss_mb': worker_rss,
            'worker_state': item.get('worker_state'),
            'worker_loaded': item.get('worker_loaded'),
            'seconds_after_unload_call': round(captured - unload_started, 3) if captured else None,
        }
summary['quick_read'] = {
    'passive_reclaim_visible_with_worker_loaded': len({v.get('worker_rss_mb') for v in summary['post_run'].values() if v.get('worker_rss_mb') is not None}) > 1,
    'explicit_unload_clears_worker_pid_immediately': summary['post_unload'].get('post_unload_immediate', {}).get('worker_loaded') in {'False', False},
}
(run_dir / 'summary.json').write_text(json.dumps(summary, indent=2) + '\n')
print(json.dumps(summary, indent=2))
PY

echo "Saved reclaim profile to $RUN_DIR"
