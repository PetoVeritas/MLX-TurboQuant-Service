#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
BASE_URL="${MLX_GEMMA_BASE_URL:-http://127.0.0.1:4017}"
MODEL_ID="${MLX_GEMMA_MODEL_ID:-mlx-gemma-test-local}"
OUT_DIR="${MLX_GEMMA_RUN_OUTPUT_DIR:-$ROOT_DIR/tmp/soak-runs}"
REQUEST_COUNT="${MLX_GEMMA_SOAK_COUNT:-12}"
SLEEP_SECONDS="${MLX_GEMMA_SOAK_SLEEP_SECONDS:-0.35}"
FIXTURE_PATH="${1:-$ROOT_DIR/benchmarks/tiny-factual.fixture.json}"
PID_FILE="$ROOT_DIR/tmp/supervisor.pid"
# shellcheck source=/dev/null
source "$ROOT_DIR/scripts/launchd-utils"

mkdir -p "$OUT_DIR"

json_get() {
  local expr="$1"
  JSON_GET_EXPR="$expr" python3 -c 'import json, os, sys; cur=json.load(sys.stdin)
for part in os.environ["JSON_GET_EXPR"].split("."):
    cur=cur[part]
print(cur)'
}

rss_mb() {
  local pid="$1"
  if [[ -z "$pid" || "$pid" == "None" ]]; then
    echo ""
    return 0
  fi
  ps -o rss= -p "$pid" 2>/dev/null | awk '{printf "%.1f", $1/1024}'
}

wait_for_stats() {
  for _ in {1..40}; do
    local body
    body="$(curl -sS "$BASE_URL/admin/stats" 2>/dev/null || true)"
    if [[ -n "$body" ]]; then
      printf '%s' "$body"
      return 0
    fi
    sleep 0.25
  done
  return 1
}

measure_json() {
  local label="$1"
  local stats
  stats="$(wait_for_stats)"
  local worker_pid supervisor_pid worker_state worker_loaded supervisor_rss worker_rss
  worker_pid="$(printf '%s' "$stats" | json_get worker.pid)"
  worker_state="$(printf '%s' "$stats" | json_get worker.state)"
  worker_loaded="$(printf '%s' "$stats" | json_get worker.loaded)"
  supervisor_pid="$(supervisor_pid_for_measurement "$PID_FILE")"
  supervisor_rss="$(rss_mb "$supervisor_pid")"
  worker_rss="$(rss_mb "$worker_pid")"
  LABEL="$label" \
  WORKER_STATE="$worker_state" \
  WORKER_LOADED="$worker_loaded" \
  SUPERVISOR_PID="$supervisor_pid" \
  SUPERVISOR_RSS_MB="$supervisor_rss" \
  WORKER_PID="$worker_pid" \
  WORKER_RSS_MB="$worker_rss" \
  python3 - <<'PY'
import json, os
print(json.dumps({
    "label": os.environ.get("LABEL", ""),
    "worker_state": os.environ.get("WORKER_STATE", ""),
    "worker_loaded": os.environ.get("WORKER_LOADED", ""),
    "supervisor_pid": os.environ.get("SUPERVISOR_PID", ""),
    "supervisor_rss_mb": os.environ.get("SUPERVISOR_RSS_MB", ""),
    "worker_pid": os.environ.get("WORKER_PID", ""),
    "worker_rss_mb": os.environ.get("WORKER_RSS_MB", ""),
}))
PY
}

TIMESTAMP="$(date -u +"%Y%m%dT%H%M%SZ")"
RUN_DIR="$OUT_DIR/${TIMESTAMP}-soak"
mkdir -p "$RUN_DIR"

cd "$ROOT_DIR"
if ! launchd_job_loaded; then
  ./scripts/start >/dev/null
fi
wait_for_stats >/dev/null

measure_json "baseline" > "$RUN_DIR/baseline.json"
./scripts/run-fixture "$FIXTURE_PATH" | tee "$RUN_DIR/cold-run.log"
measure_json "after_cold" > "$RUN_DIR/after-cold.json"

for i in $(seq 1 "$REQUEST_COUNT"); do
  ./scripts/run-fixture "$FIXTURE_PATH" | tee "$RUN_DIR/run-$i.log"
  latest_run_dir="$(ls -1dt "$ROOT_DIR"/tmp/fixture-runs/* 2>/dev/null | head -n 1)"
  if [[ -n "$latest_run_dir" && -f "$latest_run_dir/summary.json" ]]; then
    cp "$latest_run_dir/summary.json" "$RUN_DIR/run-$i-summary.json"
  fi
  measure_json "run_$i" > "$RUN_DIR/run-$i.json"
  sleep "$SLEEP_SECONDS"
done

curl -sS -X POST "$BASE_URL/admin/worker/unload" >/dev/null
sleep 1
measure_json "after_unload" > "$RUN_DIR/after-unload.json"

RUN_DIR="$RUN_DIR" REQUEST_COUNT="$REQUEST_COUNT" python3 - <<'PY'
import json, os
from pathlib import Path
run_dir = Path(os.environ['RUN_DIR'])
request_count = int(os.environ['REQUEST_COUNT'])
measurements = []
for name in ['baseline.json', 'after-cold.json'] + [f'run-{i}.json' for i in range(1, request_count + 1)] + ['after-unload.json']:
    path = run_dir / name
    if path.exists():
        measurements.append(json.loads(path.read_text()))
summary = {
    'request_count': request_count,
    'measurements': measurements,
    'cold_run_included_in_clean_pass_rate': False,
}
worker_rss_values = []
for item in measurements:
    val = item.get('worker_rss_mb')
    try:
        worker_rss_values.append(float(val))
    except Exception:
        pass
if worker_rss_values:
    summary['worker_rss_mb'] = {
        'min': min(worker_rss_values),
        'max': max(worker_rss_values),
        'delta': round(max(worker_rss_values) - min(worker_rss_values), 3),
    }
clean_passes = 0
fixture_runs = []
for summary_path in sorted(run_dir.glob('run-*-summary.json')):
    try:
        data = json.loads(summary_path.read_text())
    except Exception:
        continue
    fixture_runs.append(data)
    evaluation = data.get('evaluation') or {}
    if evaluation.get('clean_pass'):
        clean_passes += 1
summary['fixture_runs_parsed'] = len(fixture_runs)
summary['clean_passes'] = clean_passes
(run_dir / 'summary.json').write_text(json.dumps(summary, indent=2) + '\n')
print(json.dumps(summary, indent=2))
PY

echo "Saved soak profile to $RUN_DIR"
